{
  "name": "com.alga.alga.extension",
  "publisher": "SoftwareONE",
  "version": "0.0.1",
  "runtime": "wasm-js@1",
  "ui": {
    "type": "iframe",
    "entry": "ui/index.html",
    "hooks": {
      "appMenu": { "label": "SoftwareONE" },
      "clientPortalMenu": { "label": "SoftwareONE" }
    }
  },
  "api": {
    "endpoints": [
      { "method": "GET", "path": "/", "handler": "dist/main" }
    ]
  },
  "assets": [
    "ui/**/*"
  ]
}