{
  "name": "com.swo.extension",
  "publisher": "SoftwareONE",
  "version": "0.0.9",
  "runtime": "wasm-js@1",
  "capabilities": [
    "cap:context.read",
    "cap:log.emit",
    "cap:secrets.get",
    "cap:http.fetch",
    "cap:ui.proxy",
    "cap:storage.kv"
  ],
  "ui": {
    "type": "iframe",
    "entry": "ui/index.html",
    "hooks": {
      "appMenu": { "label": "Software20" },
      "clientPortalMenu": { "label": "Software20" }
    }
  },
  "assets": ["ui/**/*"]
}