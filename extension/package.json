{
  "name": "swo-alga-ext",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "rimraf dist",
    "build": "npm run build:ui && npm run build:backend && npm run build:wasm && npm run pack",
    "build-deploy": "npm run build && npm run deploy",
    "postbuild": "node scripts/postbuild.mjs",
    "build:ui": "tsc -b && BUILD_TARGET=ui vite build",
    "build:backend": "tsup",
    "build:wasm": "jco componentize dist/js/handler.js --wit ./wit/extension-runner.wit --world-name runner --disable all --out dist/main.wasm",
    "pack": "alga pack",
    "deploy": "node scripts/deploy.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "alga-proxy": "npx local-cors-proxy --proxyUrl https://algapsa.com --port 8010"
  },
  "dependencies": {
    "@alga-psa/extension-iframe-sdk": "^0.1.0",
    "@alga-psa/extension-runtime": "^0.3.0",
    "@alga-psa/ui-kit": "^0.2.0",
    "@headlessui/react": "^2.2.7",
    "@swo/mp-api-model": "^5.1.297",
    "@swo/rql-client": "^5.0.3",
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/react-query": "^5.85.9",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.11.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.18",
    "lucide-react": "^0.544.0",
    "path-to-regexp": "^6.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.69.0",
    "react-router": "^7.8.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@alga-psa/cli": "^0.2.0",
    "@bytecodealliance/componentize-js": "^0.19.3",
    "@bytecodealliance/jco": "^1.15.3",
    "@eslint/js": "^9.33.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "playwright": "^1.58.1",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4.1.12",
    "tsup": "^8.5.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2"
  }
}
